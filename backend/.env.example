# ============================================================
# PocketBuddy Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values:
#   copy .env.example .env
# ============================================================

# === DATABASE (Required) ===

# MongoDB connection string.
# For MongoDB Atlas: mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/?appName=pocketbuddy&tls=true&tlsAllowInvalidCertificates=true
# For local MongoDB: mongodb://localhost:27017
#
# ⚠️ WARNING: If your password contains special characters (@, #, %, etc.), 
# you MUST URL-encode them! Example: @ becomes %40, # becomes %23
# See REPRODUCIBILITY.md for the full encoding table.
MONGO_URL=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/?appName=pocketbuddy&tls=true&tlsAllowInvalidCertificates=true

# Database name within MongoDB (must match across team)
DB_NAME=pocketbuddy

# === AUTHENTICATION (Required) ===

# Secret key for signing JWT tokens. Use any random string, 32+ characters.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️ If you change this after users have registered, all existing sessions become invalid.
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# === CORS (Required) ===

# Comma-separated list of frontend URLs allowed to call this API.
# Include ALL ports your frontend might run on.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# === AI ENGINE: Multi-Provider API Keys ===
# At least ONE key is required for chat features to work.
# Leave unused providers blank.

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Google Gemini (https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=

# Groq (https://console.groq.com/keys) — has a free tier
GROQ_API_KEY=

# Legacy key (backward compat — if set and OPENAI_API_KEY is empty, this is used as the OpenAI key)
EMERGENT_LLM_KEY=
