# ============================================================
# PocketBuddy Frontend — Environment Variables
# ============================================================
# Copy this file to .env and adjust if needed:
#   copy .env.example .env
# ============================================================

# Backend API URL (no trailing slash!)
# Default: http://localhost:8000 (local backend dev server)
# Change this to your deployed backend URL for production.
REACT_APP_BACKEND_URL=http://localhost:8000

# Optional: Enable webpack health check plugin (dev only, usually not needed)
# ENABLE_HEALTH_CHECK=false
